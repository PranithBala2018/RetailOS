# Copy to .env for `docker compose up`. Never commit a real .env.
# See SPRINT0.md §11 (Secrets Management).

POSTGRES_USER=retailos
POSTGRES_PASSWORD=retailos
POSTGRES_DB=retailos
POSTGRES_PORT=5432

REDIS_PORT=6379

API_PORT=8000
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
API_JWT_SECRET_KEY=replace-with-a-locally-generated-secret-at-least-32-bytes-long
