# Copy to .env for local, non-Docker backend development.
# Never commit a real .env — see SPRINT0.md §11 (Secrets Management).
# All variables are prefixed API_ per app/core/config.py (env_prefix="API_").

API_PROJECT_NAME="RetailOS API"
API_ENVIRONMENT=development
API_DEBUG=true

API_DATABASE_URL=postgresql+asyncpg://retailos:retailos@localhost:5432/retailos
API_DB_ECHO=false
API_DB_POOL_SIZE=10
API_DB_MAX_OVERFLOW=20

API_REDIS_URL=redis://localhost:6379/0

# Generate a real secret with: python -c "import secrets; print(secrets.token_urlsafe(64))"
API_JWT_SECRET_KEY=replace-with-a-locally-generated-secret-at-least-32-bytes-long
API_JWT_ALGORITHM=HS256
API_ACCESS_TOKEN_EXPIRE_MINUTES=15
API_REFRESH_TOKEN_EXPIRE_DAYS=30

API_CORS_ALLOW_ORIGINS=["http://localhost:3000"]

API_LOG_LEVEL=DEBUG
API_LOG_JSON=false
