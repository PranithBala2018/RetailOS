# --- Secrets / environment ---
.env
.env.*
!.env.example
!*/.env.example

# --- Python (backend) ---
backend/.venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# --- Flutter / Dart (frontend) ---
frontend/.dart_tool/
